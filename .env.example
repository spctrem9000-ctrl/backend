PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/divado?schema=public"

JWT_SECRET="your_jwt_access_secret_key"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key"

# Storage Configuration
# Set to 'local' for local development or 'r2' for Cloudflare R2 cloud storage
STORAGE_DRIVER=local

# Local Storage settings
LOCAL_PUBLIC_URL=http://localhost:3000/uploads

# Cloudflare R2 settings
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=divado-uploads
# Leave R2_ENDPOINT empty to auto-generate based on Account ID, or provide a custom one
R2_ENDPOINT=
# The public custom domain pointing to your R2 bucket
R2_PUBLIC_URL=https://cdn.divado.com
