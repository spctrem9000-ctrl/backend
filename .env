NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://divado:divado123@localhost:5432/divado_db?schema=public"

# Security
JWT_SECRET="local_jwt_secret_change_me_super_long_key"
JWT_REFRESH_SECRET="local_jwt_refresh_secret_change_me_super_long_key"

# Storage Configuration
STORAGE_DRIVER=r2 # "local" or "r2"

# Cloudflare R2 Storage (Used if STORAGE_DRIVER=r2)
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key"
R2_SECRET_ACCESS_KEY="your_r2_secret_key"
R2_BUCKET_NAME="divado-bucket0"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxx.r2.dev"
